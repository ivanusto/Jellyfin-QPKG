#!/bin/bash

# Default variables (can be overridden)
PACKAGE_NAME="${PACKAGE_NAME:-jellyfin}"
DOCKER_IMAGE="${DOCKER_IMAGE:-jellyfin/jellyfin:latest}"


# Unified logging functions
log() {
    local MESSAGE="$(date '+%Y-%m-%d %H:%M:%S') [INFO] $*"
    echo "$MESSAGE"
    /sbin/log_tool -t0 -uSystem -p127.0.0.1 -mlocalhost -a "$MESSAGE"
}
warn_log() {
    local MESSAGE="$(date '+%Y-%m-%d %H:%M:%S') [WARN] $*"
    echo "$MESSAGE"
    /sbin/log_tool -t1 -uSystem -p127.0.0.1 -mlocalhost -a "$MESSAGE"
}
err_log() {
    local MESSAGE="$(date '+%Y-%m-%d %H:%M:%S') [ERROR] $*"
    echo "$MESSAGE"
    /sbin/log_tool -t2 -uSystem -p127.0.0.1 -mlocalhost -a "$MESSAGE"
    exit 1
}

no_op() {
    log "No operation specified. Running a placeholder function."
}

detect_primary_volume() {
    PRIMARY_VOLUME=$(getcfg SHARE_DEF defVolMP -d "" -f /etc/config/def_share.info)
    [ -z "$PRIMARY_VOLUME" ] && err_log "Primary volume not found. Exiting."
}

resolve_qpkg_path() {
    # Try to read Install_Path directly from qpkg.conf first if already registered
    QPKG_PATH=$(/sbin/getcfg "$PACKAGE_NAME" Install_Path -f /etc/config/qpkg.conf)
    if [ -z "$QPKG_PATH" ] || [ ! -d "$QPKG_PATH" ]; then
        # Fallback to reconstructing the path from primary volume
        detect_primary_volume
        QPKG_DIR="${PRIMARY_VOLUME}/.qpkg"
        if [ -L "$QPKG_DIR" ]; then
            QPKG_DIR=$(readlink -f "$QPKG_DIR")
        fi
        QPKG_PATH="${QPKG_DIR}/${PACKAGE_NAME}"
    fi
    CONFIG_DIR="${QPKG_PATH}/config"
}

verify_container_station() {
    CONTAINER_STATION_DIR=$(/sbin/getcfg container-station Install_Path -f /etc/config/qpkg.conf)
    if [ -z "$CONTAINER_STATION_DIR" ] || [ ! -d "$CONTAINER_STATION_DIR" ]; then
        err_log "Container Station not installed."
    fi
}

prepare_directories() {
    mkdir -p "$QPKG_PATH" "$CONFIG_DIR" || err_log "Failed to create directories at $QPKG_PATH or $CONFIG_DIR."
    log "Directories prepared successfully."
}

detect_docker_binary() {
    local max_wait=120
    local elapsed=0
    DOCKER_PATH=""

    # If action is stop, check quickly without waiting/looping
    if [ "$ACTION" = "stop" ]; then
        max_wait=0
    fi

    while :; do
        CONTAINER_STATION_DIR=$(/sbin/getcfg container-station Install_Path -f /etc/config/qpkg.conf)
        if [ -n "$CONTAINER_STATION_DIR" ] && [ -x "${CONTAINER_STATION_DIR}/bin/docker" ]; then
            DOCKER_PATH="${CONTAINER_STATION_DIR}/bin/docker"
            break
        elif which docker >/dev/null 2>&1; then
            DOCKER_PATH=$(which docker)
            break
        fi

        if [ $elapsed -ge $max_wait ]; then
            break
        fi

        log "Waiting for Docker binary to be available... (${elapsed}/${max_wait}s)"
        sleep 2
        elapsed=$((elapsed + 2))
    done

    if [ -z "$DOCKER_PATH" ]; then
        if [ "$ACTION" = "stop" ]; then
            log "Docker binary not found or not executable during stop. Assuming already stopped."
            exit 0
        else
            err_log "Docker binary not found or not executable after ${max_wait}s."
        fi
    fi
    export PATH="$(dirname "$DOCKER_PATH"):$PATH"
}

detect_docker_compose() {
    detect_docker_binary
    if "$DOCKER_PATH" compose version >/dev/null 2>&1; then
        DOCKER_COMPOSE_CMD="$DOCKER_PATH compose"
    elif [ -n "$CONTAINER_STATION_DIR" ] && [ -x "${CONTAINER_STATION_DIR}/bin/docker-compose" ]; then
        DOCKER_COMPOSE_CMD="${CONTAINER_STATION_DIR}/bin/docker-compose"
    elif which docker-compose >/dev/null 2>&1; then
        DOCKER_COMPOSE_CMD="docker-compose"
    else
        if [ "$ACTION" = "stop" ]; then
            log "docker compose not found during stop. Assuming already stopped."
            exit 0
        else
            err_log "docker compose not found. Install Docker Compose plugin."
        fi
    fi
}

wait_for_docker_daemon() {
    local max_wait=120
    local elapsed=0
    log "Waiting for Docker daemon to respond..."
    while [ $elapsed -lt $max_wait ]; do
        if "$DOCKER_PATH" version >/dev/null 2>&1; then
            log "Docker daemon is responsive."
            return 0
        fi
        sleep 2
        elapsed=$((elapsed + 2))
    done
    err_log "Docker daemon did not respond after ${max_wait}s."
}

create_all_mounts_file() {
    log "Creating all_mounts file"
    detect_primary_volume
    resolve_qpkg_path
    SMB_CONF="/etc/config/smb.conf"
    ALL_MOUNTS_FILE="${CONFIG_DIR}/all_mounts"
    [ ! -f "$SMB_CONF" ] && err_log "Missing smb.conf: $SMB_CONF"
    mkdir -p "$CONFIG_DIR" || err_log "Failed to create config dir: $CONFIG_DIR"
    > "$ALL_MOUNTS_FILE"
    grep "^\[" "$SMB_CONF" | sed 's/\[\(.*\)\]/\1/' | while read -r SHARE_NAME; do
        # Exclude special sections in smb.conf
        [ "$SHARE_NAME" = "global" ] && continue
        [ "$SHARE_NAME" = "printers" ] && continue
        [ "$SHARE_NAME" = "homes" ] && continue
        SHARE_PATH=$(/sbin/getcfg "$SHARE_NAME" path -f "$SMB_CONF")
        if [ -n "$SHARE_PATH" ] && [ -d "$SHARE_PATH" ]; then
            if [ -w "$SHARE_PATH" ]; then
                CONTAINER_PATH="/mnt/${SHARE_NAME}"
                echo "-v ${SHARE_PATH}:${CONTAINER_PATH}:rw" >> "$ALL_MOUNTS_FILE"
            else
                warn_log "Skipping read-only share: $SHARE_NAME ($SHARE_PATH)"
            fi
        else
            warn_log "Skipping invalid/missing share: $SHARE_NAME ($SHARE_PATH)"
        fi
    done
}

create_docker_compose_file() {
    create_all_mounts_file
    COMPOSE_FILE="${QPKG_PATH}/docker-compose.yml"
    cat > "$COMPOSE_FILE" <<EOF
version: "3.8"
services:
  ${PACKAGE_NAME}:
    image: ${DOCKER_IMAGE}
    container_name: ${PACKAGE_NAME}
    ports:
      - "8096:8096"
    volumes:
      - "${CONFIG_DIR}:/config"
EOF

    MOUNT_FILE="${CONFIG_DIR}/all_mounts"
    [ -f "$MOUNT_FILE" ] && while IFS= read -r LINE; do
        [[ $LINE == -v* ]] && echo "      - \"$(echo "$LINE" | sed 's/^-v //')\"" >> "$COMPOSE_FILE"
    done < "$MOUNT_FILE"

    # Prepare devices block dynamically to avoid duplicate yaml keys
    DEVICES_ENTRIES=""
    if [ -d "/dev/dri" ] || [ -c "/dev/dri/renderD128" ]; then
        log "Intel GPU detected on host. Preparing Intel GPU devices mapping."
        DEVICES_ENTRIES="${DEVICES_ENTRIES}      - \"/dev/dri:/dev/dri\"\n"
    fi

    NVIDIA_DRV_PATH=$(/sbin/getcfg NVIDIA_GPU_DRV Install_Path -f /etc/config/qpkg.conf)
    if [ -c "/dev/nvidia0" ] && [ -n "$NVIDIA_DRV_PATH" ] && [ -d "$NVIDIA_DRV_PATH" ]; then
        log "NVIDIA GPU and drivers detected on host. Preparing NVIDIA GPU devices mapping."
        DEVICES_ENTRIES="${DEVICES_ENTRIES}      - \"/dev/nvidia0:/dev/nvidia0\"\n      - \"/dev/nvidiactl:/dev/nvidiactl\"\n      - \"/dev/nvidia-uvm:/dev/nvidia-uvm\"\n"
        # Mount NVIDIA driver to volumes
        echo "      - \"${NVIDIA_DRV_PATH}/usr:/usr/local/nvidia:ro\"" >> "$COMPOSE_FILE"
    fi

    if [ -n "$DEVICES_ENTRIES" ]; then
        echo "    devices:" >> "$COMPOSE_FILE"
        printf "%b" "$DEVICES_ENTRIES" >> "$COMPOSE_FILE"
    fi

    # Append NVIDIA environment variables if NVIDIA was detected
    if [ -c "/dev/nvidia0" ] && [ -n "$NVIDIA_DRV_PATH" ] && [ -d "$NVIDIA_DRV_PATH" ]; then
        cat >> "$COMPOSE_FILE" <<EOF
    environment:
      - "LD_LIBRARY_PATH=/usr/local/nvidia/lib64"
      - "NVIDIA_VISIBLE_DEVICES=all"
      - "NVIDIA_DRIVER_CAPABILITIES=all"
EOF
    fi

    log "Docker Compose file created at: $COMPOSE_FILE"
}

create_container() {
    log "Creating ${PACKAGE_NAME} container..."
    create_docker_compose_file
    DC_FILE="${QPKG_PATH}/docker-compose.yml"
    $DOCKER_COMPOSE_CMD -f "$DC_FILE" up -d || err_log "Failed to start ${PACKAGE_NAME} container."
    log "${PACKAGE_NAME} container started successfully."
}

pkg_install() {
    log "Installing ${PACKAGE_NAME}..."
    detect_primary_volume
    resolve_qpkg_path
    verify_container_station
    detect_docker_compose
    wait_for_docker_daemon
    prepare_directories
    local PACKAGE_ROUTINES_SRC="$(dirname "$0")/package_routines"
    [ ! -f "$PACKAGE_ROUTINES_SRC" ] && err_log "Missing package_routines at $(dirname "$0")"
    cp "$PACKAGE_ROUTINES_SRC" "$QPKG_PATH" || err_log "Could not copy package_routines."
    "$DOCKER_PATH" pull "$DOCKER_IMAGE" || err_log "Docker pull failed for image $DOCKER_IMAGE"
    create_container
    pkg_start
}

pkg_post_install() {
    log "Post-installation for ${PACKAGE_NAME}..."
    resolve_qpkg_path
    /sbin/setcfg "$PACKAGE_NAME" depend_on "container-station" -f /etc/config/qpkg.conf
    /sbin/setcfg "$PACKAGE_NAME" Timeout "120,60" -f /etc/config/qpkg.conf
    /sbin/setcfg "$PACKAGE_NAME" Enable TRUE -f /etc/config/qpkg.conf
    log "Post-install complete."
}

pkg_start() {
    log "Starting ${PACKAGE_NAME}..."
    detect_primary_volume
    resolve_qpkg_path
    detect_docker_compose
    wait_for_docker_daemon
    DC_FILE="${QPKG_PATH}/docker-compose.yml"
    $DOCKER_COMPOSE_CMD -f "$DC_FILE" up -d
    RUNNING_SERVICE=$($DOCKER_COMPOSE_CMD -f "$DC_FILE" ps --services --filter "status=running" | grep -w "${PACKAGE_NAME}")
    [ -n "$RUNNING_SERVICE" ] && log "Container started." || err_log "Failed to start container."
}

pkg_stop() {
    log "Stopping ${PACKAGE_NAME}..."
    detect_docker_compose
    detect_primary_volume
    resolve_qpkg_path
    DC_FILE="${QPKG_PATH}/docker-compose.yml"

    # If the docker daemon is not responsive during stop, don't hang/error.
    if ! "$DOCKER_PATH" version >/dev/null 2>&1; then
        log "Docker daemon not running or not responsive during stop. Assuming already stopped."
        exit 0
    fi

    $DOCKER_COMPOSE_CMD -f "$DC_FILE" stop
    RUNNING_SERVICE=$($DOCKER_COMPOSE_CMD -f "$DC_FILE" ps --services --filter "status=running" | grep -w "${PACKAGE_NAME}")
    [ -z "$RUNNING_SERVICE" ] && log "Container stopped." || err_log "Stop failed."
}

PKG_PRE_REMOVE="{
    PACKAGE_NAME=\"\${PACKAGE_NAME:-jellyfin}\"
    /sbin/log_tool -t0 -uSystem -p127.0.0.1 -mlocalhost -a '[INFO] PKG_PRE_REMOVE: Starting...'
    CONTAINER_STATION_DIR=\$(/sbin/getcfg container-station Install_Path -f /etc/config/qpkg.conf)
    if [ -n \"\$CONTAINER_STATION_DIR\" ] && [ -x \"\${CONTAINER_STATION_DIR}/bin/docker\" ]; then
        DOCKER_PATH=\"\${CONTAINER_STATION_DIR}/bin/docker\"
        DOCKER_COMPOSE_CMD=\"\${DOCKER_PATH} compose\"
    else
        DOCKER_PATH=\$(which docker)
        if [ -n \"\$DOCKER_PATH\" ] && \"\$DOCKER_PATH\" compose version >/dev/null 2>&1; then
            DOCKER_COMPOSE_CMD=\"\${DOCKER_PATH} compose\"
        elif which docker-compose >/dev/null 2>&1; then
            DOCKER_COMPOSE_CMD=\"docker-compose\"
        else
            DOCKER_COMPOSE_CMD=\"docker compose\"
        fi
    fi
    QPKG_DIR=\$(/sbin/getcfg \"\$PACKAGE_NAME\" Install_Path -f /etc/config/qpkg.conf)
    if [ -z \"\$QPKG_DIR\" ] || [ ! -d \"\$QPKG_DIR\" ]; then
        PRIMARY_VOLUME=\$(getcfg SHARE_DEF defVolMP -d '' -f /etc/config/def_share.info)
        QPKG_DIR=\"\${PRIMARY_VOLUME}/.qpkg/\${PACKAGE_NAME}\"
    fi
    DC_FILE=\"\${QPKG_DIR}/docker-compose.yml\"
    cd \"\$QPKG_DIR\" || exit 1
    /sbin/log_tool -t0 -uSystem -p127.0.0.1 -mlocalhost -a '[INFO] Stopping container...'
    OUTPUT=\$(\$DOCKER_COMPOSE_CMD -f \"\$DC_FILE\" down 2>&1)
    /sbin/log_tool -t0 -uSystem -p127.0.0.1 -mlocalhost -a \"[INFO] docker compose down: \$OUTPUT\"
}"

# Main Entry Point
if [ -z "$1" ]; then
    set -- no_op
fi

ACTION="$1"

case "$ACTION" in
    install) pkg_install ;;
    start) pkg_start ;;
    stop) pkg_stop ;;
    no_op) no_op ;;
    *) err_log "Invalid action: $ACTION. Use install, start, stop, or no_op." ;;
esac
